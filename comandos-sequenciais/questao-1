// Questão 1. Faça um algoritmo que recebe dois valores inteiros e mostra o resultado da multiplicação.

#include <stdio.h>
#include <locale.h>

int main() 
{
    setlocale(LC_ALL, "Portuguese");

    int x, y, resultado;

    printf("Digite o primeiro número: ");
    scanf("%d", &x);

    printf("Digite o segundo número: ");
    scanf("%d", &y);

    resultado = x * y;

    printf("Resultado: %d x %d = %d\n", x, y, resultado);

    return 0;
} 

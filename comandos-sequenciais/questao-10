 // Questão 10. Faça um algoritmo que mostra a quantidade de cédulas de um caixa eletrônico de um banco. O algoritmo recebe como entrada o valor inteiro a ser sacado pelo cliente, em seguida apresente a quantidade de cada cédula que o cliente deverá receber, de forma que a quantidade de cédulas seja o menor possível.

#include <stdio.h>

int main() {
    int valor, cedulas;
    int notas[] = {200, 100, 50, 20, 10, 5, 2, 1};
    int tamanho = 8;

    printf("Digite o valor a ser sacado: R$ ");
    scanf("%d", &valor);

    if (valor <= 0) {
        printf("Valor inválido!\n");
        return 1;
    }

    printf("\n--- Cédulas a receber ---\n");

    for (int i = 0; i < tamanho; i++) {
        cedulas = valor / notas[i];

        if (cedulas > 0) {
            printf("Cédulas de R$ %3d: %d\n", notas[i], cedulas);
            valor = valor % notas[i];
        }
    }

    if (valor > 0) {
        printf("Valor restante não pode ser fornecido em cédulas.\n");
    }

    return 0;
}

 // Questão 6. Faça um algoritmo que recebe o valor do raio de um círculo e apresenta o valor da área desse círculo.

#include <stdio.h>

#define PI 3.14159

int main() {
    float raio, area;

    printf("Digite o valor do raio: ");
    scanf("%f", &raio);

    area = PI * raio * raio;

    printf("Raio: %.2f\n", raio);
    printf("Área do círculo: %.2f\n", area);

    return 0;
}

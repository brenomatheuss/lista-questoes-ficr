// Questão 2. Fazer um algoritmo que leia um número e mostre o seu antecessor e o seu sucessor.

#include <stdio.h>
#include <locale.h>

int main() {
    
    setlocale(LC_ALL, "Portuguese");
    
    int numero, antecessor, sucessor;

    printf("Digite um numero: ");
    scanf("%d", &numero);

    antecessor = numero - 1;
    sucessor = numero + 1;

    printf("Antecessor: %d\n", antecessor);
    printf("Sucessor: %d\n", sucessor);

    return 0;
} 

 // Questão 7. Fazer um algoritmo que calcule e mostre a área e o volume de um cilindro. (A =2πr(h+r),V = πr2h).

#include <stdio.h>

#define PI 3.14159

int main() {
    float raio, altura, area, volume;

    printf("Digite o valor do raio: ");
    scanf("%f", &raio);

    printf("Digite o valor da altura: ");
    scanf("%f", &altura);

    area   = 2 * PI * raio * (altura + raio);
    volume = PI * raio * raio * altura;

    printf("\n--- Resultados ---\n");
    printf("Raio:   %.2f\n", raio);
    printf("Altura: %.2f\n", altura);
    printf("Área do cilindro:   %.2f\n", area);
    printf("Volume do cilindro: %.2f\n", volume);

    return 0;
}

 // Questão 11. Faça um algoritmo que auxiliará um funcionário de um caixa de supermercado. O algoritmo deverá receber como entrada o valor da compra do cliente e o valor pago pelo cliente, em seguida o algoritmo deverá apresentar o troco da compra, de forma que o mesmo deve apresentar a quantidade de cédulas e moedas para compor o troco do cliente.

#include <stdio.h>

int main() {
    float valor_compra, valor_pago;
    int troco, quantidade;

    int cedulas[] = {200, 100, 50, 20, 10, 5, 2};
    int moedas[]  = {100, 50, 25, 10, 5, 1};
    int tam_cedulas = 7;
    int tam_moedas  = 6;

    printf("Digite o valor da compra: R$ ");
    scanf("%f", &valor_compra);

    printf("Digite o valor pago:      R$ ");
    scanf("%f", &valor_pago);

    if (valor_pago < valor_compra) {
        printf("\nValor pago insuficiente!\n");
        return 1;
    }

    troco = (int)((valor_pago - valor_compra) * 100 + 0.5);

    printf("\nValor da compra: R$ %.2f\n", valor_compra);
    printf("Valor pago:      R$ %.2f\n", valor_pago);
    printf("Troco:           R$ %.2f\n", troco / 100.0);

    if (troco == 0) {
        printf("\nSem troco!\n");
        return 0;
    }

    printf("\n--- Cédulas ---\n");
    for (int i = 0; i < tam_cedulas; i++) {
        quantidade = troco / cedulas[i];
        if (quantidade > 0) {
            printf("Cédulas de R$ %6.2f: %d\n", cedulas[i] / 100.0, quantidade);
            troco = troco % cedulas[i];
        }
    }

    printf("\n--- Moedas ---\n");
    for (int i = 0; i < tam_moedas; i++) {
        quantidade = troco / moedas[i];
        if (quantidade > 0) {
            printf("Moedas  de R$ %6.2f: %d\n", moedas[i] / 100.0, quantidade);
            troco = troco % moedas[i];
        }
    }

    return 0;
}

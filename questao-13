 // Questão 13. O preço de um automóvel é calculado pela soma do preço de fábrica, o preço dos impostos (45% do preço de fábrica) e a porcentagem do revendedor (28% do preço de fábrica). Fazer um algoritmo que leia o preço de fábrica. Calcule e mostre o preço final do carro.

#include <stdio.h>

int main() {
    float preco_fabrica, impostos, comissao, preco_final;

    printf("Digite o preço de fábrica: R$ ");
    scanf("%f", &preco_fabrica);

    impostos = preco_fabrica * 0.45;
    comissao = preco_fabrica * 0.28;

    preco_final = preco_fabrica + impostos + comissao;

    printf("\n--- Composição do Preço ---\n");
    printf("Preço de fábrica:       R$ %10.2f\n", preco_fabrica);
    printf("Impostos        (45%%):  R$ %10.2f\n", impostos);
    printf("Revendedor      (28%%):  R$ %10.2f\n", comissao);
    printf("--------------------------------\n");
    printf("Preço final:            R$ %10.2f\n", preco_final);

    return 0;
}

// Questão 3. Fazer um algoritmo que obtenha dois números inteiros, x e y, mostre o quociente e o resto da divisão inteira entre eles.

#include <stdio.h>
#include <locale.h>

int main(){
    setlocale(LC_ALL, "Portuguese");

    int x, y, quociente, resto;

    printf("Digite o primeiro número: ");
    scanf("%d", &x);

    printf("Digite o segundo número: ");
    scanf("%d", &y);

    if (y == 0) {
        printf("Erro: divisão por zero!");
        return 1;
    }

    quociente = x / y;
    resto = x % y;

    printf("O resultado da divisão é: %d", quociente);
    printf("\nO resto da divisão é: %d", resto);

    return 0;
}
